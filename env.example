# ══════════════════════════════════════════════
#   TelegramCRM — .env.example
#   Скопируй в .env и заполни все поля
#   НЕ коммить .env в git!
# ══════════════════════════════════════════════

# ── Telegram боты ──────────────────────────────
BOT_TOKEN=                      # CRM бот (@BotFather)
MASTER_BOT_TOKEN=               # Мастер-бот (@BotFather)
CRM_BOT_USERNAME=mycrm_bot      # username CRM бота без @
MASTER_ADMIN_TG_ID=             # твой числовой Telegram ID (@userinfobot)

# ── База данных ─────────────────────────────────
POSTGRES_DB=crm_db
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=              # openssl rand -hex 32
DATABASE_URL=postgresql+asyncpg://crm_user:СЮДА_POSTGRES_PASSWORD@postgres:5432/crm_db

# ── Redis ───────────────────────────────────────
REDIS_PASSWORD=                 # openssl rand -hex 32
REDIS_URL=redis://:СЮДА_REDIS_PASSWORD@redis:6379/3
USE_REDIS=true

# ── API сервер ──────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Домен ───────────────────────────────────────
PUBLIC_DOMAIN=yourdomain.com    # без https://
ACME_EMAIL=your@email.com       # для Let's Encrypt

# ── Подписки ─────────────────────────────────────
SUBSCRIPTION_PRICE=1500
SUBSCRIPTION_DAYS=30
TRIAL_DAYS=14
REFERRAL_BONUS_DAYS=7
SUPPORT_USERNAME=@your_support

# ── SLA дефолты (применяются при создании тенанта)
SLA_NEW_HOURS=2
SLA_IN_PROGRESS_DAYS=3

# ── ЮКасса ──────────────────────────────────────
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
